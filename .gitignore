# ═══ PARKVISION AI — .gitignore ═══

# ── Python ──────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual Environment ────────────
venv/
env/
.venv/

# ── IDE ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Environment & Secrets ──────────
.env
*.key

# ── Large Data Files ───────────────
# These are generated by the pipeline — too large for GitHub
data/*.parquet
data/*.pkl
data/*.geojson
data/*.graphml
data/.pipeline_checkpoint.json
data/users.json

# ── Large Output Files ─────────────
output/*.geojson

# ── Model Files ────────────────────
models/*.joblib
models/*.pkl

# ── Raw Dataset ────────────────────
*.csv

# ── Keep directory structure ───────
!data/.gitkeep
!output/.gitkeep
!models/.gitkeep

# SSH keys
*.pem
*.ppk

# Deployment scripts
configure_server.sh
finalize_deploy.sh
install_python.sh
server_setup.sh
