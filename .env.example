# PARKVISION AI — Environment Variables Template
# 
# Copy this file to .env and fill in your API keys:
#   Windows:  copy .env.example .env
#   Linux:    cp .env.example .env
#
# NEVER commit your .env file to Git. It is already in .gitignore.

# ── NVIDIA NIM (required for AI Chat) ─────────────────────────────
# Get your free key at: https://build.nvidia.com
# Free tier: generous rate limits on LLaMA-3.3-70B
NVIDIA_API_KEY=your-nvidia-nim-key-here

# ── TomTom Maps (optional) ─────────────────────────────────────────
# Get your free key at: https://developer.tomtom.com
# Free tier: 2,500 requests/day. Falls back to CartoDB if missing.
TOMTOM_API_KEY=your-tomtom-key-here

# ── Google Gemini (optional fallback) ──────────────────────────────
# Get your free key at: https://aistudio.google.com
# Used as fallback if NVIDIA_API_KEY is not set.
GEMINI_API_KEY=your-gemini-key-here
